# Supabase Postgres. Use the *session pooler* connection string
# (aws-x-xx.pooler.supabase.com:5432) -- the direct connection is IPv6-only
# and Render's free tier can't reach it.
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# HubSpot private app access token (Settings -> Integrations -> Private Apps).
# Needs crm.objects.contacts.read/write and crm.objects.deals.read/write
# (write is only used by the seed script).
HUBSPOT_TOKEN=pat-na1-...

# Stripe test-mode secret key (Developers -> API keys).
STRIPE_SECRET_KEY=sk_test_...

# Google service account credentials: either a path to the JSON key file,
# or the JSON itself pasted inline (useful on Render where there's no disk).
# The target calendar must be shared with the service account's email.
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
GOOGLE_CALENDAR_ID=you@example.com

# Optional shared secret for POST /sync/run on the public deployment.
# Leave empty locally to skip the check.
SYNC_API_KEY=

# Minutes between automatic sync runs inside the web process. 0 disables
# the loop; POST /sync/run always works either way.
SYNC_INTERVAL_MINUTES=0
